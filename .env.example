# Copy to `.env.local` (gitignored) for local dev, and set the same keys on Vercel → Environment Variables.

# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or newer publishable key (sb_publishable_...) — both work with createClient
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# If unset, the app uses defaults in `src/lib/supabaseDefaults.ts` (US project; set vars above to use another region later).
